{
  "name": "saudaa",
  "version": "1.0.0",
  "description": "Saudaa - Verified Traders Marketplace and Live Trade Signals (India)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build:css": "tailwindcss -i ./src/input.css -o ./public/tailwind.css --minify",
    "build": "npm run build:css",
    "watch:css": "tailwindcss -i ./src/input.css -o ./public/tailwind.css --watch",
    "test": "jest --runInBand --forceExit",
    "test:ci": "jest --ci --runInBand --forceExit --coverage"
  },
  "keywords": [
    "trading",
    "signals",
    "india",
    "nifty",
    "verified-traders"
  ],
  "author": "Sahil",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@supabase/supabase-js": "^2.43.4",
    "express": "^5.2.1",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "nodemailer": "^6.9.14",
    "playwright": "^1.60.0",
    "razorpay": "^2.9.2"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.7",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.4.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
