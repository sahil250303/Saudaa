# ── Saudaa Environment Variables ──────────────────────────────────────────────
# Copy this file to .env and fill in all values before running locally.
# NEVER commit .env to version control — it is already in .gitignore.

# ── Required: Authentication ──────────────────────────────────────────────────
# Secret used to sign user & admin JWT tokens. Generate with:
#   node -e "require('crypto').randomBytes(48).toString('hex')" | pbcopy
SESSION_SECRET=your-strong-random-secret-here

# ── Required: Database (Supabase) ─────────────────────────────────────────────
# Use the SERVICE ROLE key — NOT the public anon/publishable key.
# Find it in: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-service-role-key-here

# ── Optional: Market Data ─────────────────────────────────────────────────────
# Free key from https://www.alphavantage.co/support/
# If unset, market ticker runs in simulated mode (shows ⚠ Simulated badge to users).
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key-here

# ── Optional: Payments (Razorpay) ─────────────────────────────────────────────
# Required before accepting real payments. Get keys from https://razorpay.com
# If unset in production, /api/subscribe returns HTTP 503.
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret-here

# ── Optional: Admin Credentials (first run only) ──────────────────────────────
# Used only if the admin table in Supabase is empty (first-time setup).
# After first run, change the password via the admin panel.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-immediately

# ── Optional: Transactional Email (SMTP) ─────────────────────────────────────
# Required to send post-subscription welcome/invoice emails to users.
# Works with any SMTP provider: Gmail, SendGrid, AWS SES, Mailgun, Brevo, etc.
#
# Gmail example (use an App Password, not your main password):
#   EMAIL_HOST=smtp.gmail.com
#   EMAIL_PORT=587
#   EMAIL_SECURE=false
#   EMAIL_USER=youraddress@gmail.com
#   EMAIL_PASS=your-app-password-here
#
# SendGrid example:
#   EMAIL_HOST=smtp.sendgrid.net
#   EMAIL_PORT=587
#   EMAIL_SECURE=false
#   EMAIL_USER=apikey
#   EMAIL_PASS=SG.xxxxxxxxxxxxxxxxxxxxxxxxxx
#
# If unset, emails are silently skipped — no crash, just a console warning.
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-smtp-username
EMAIL_PASS=your-smtp-password
EMAIL_FROM=Saudaa <noreply@saudaa.in>

# Optional: Override the base URL used in email CTAs (defaults to https://saudaa.vercel.app)
APP_URL=https://saudaa.vercel.app

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
